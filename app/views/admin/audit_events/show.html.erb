<% event = @activity.event %>

<div class="admin-page">
  <div class="row">
    <div class="col-sm-12">
      <p class="mb-1"><%= link_to "Back to Audit Trail", admin_audit_events_path %></p>
      <h2>
        <%= audit_badge(@activity.headline_event) %>
        <span class="text-muted"><%= @activity.headline_type %>:</span>
        <%= @activity.headline_name %>
      </h2>
      <p class="text-muted">
        <% if event %>
          By <%= event.actor_label %> on <%= event.created_at&.strftime("%Y-%m-%d %H:%M") %>
          · <%= pluralize(event.version_count, "record") %> changed
        <% end %>
      </p>
    </div>
  </div>

  <h3 class="section-header">Field changes</h3>
  <% if @activity.parent_changes.any? %>
    <table class="table table-sm table-bordered">
      <thead>
        <tr><th>Field</th><th>From</th><th>To</th></tr>
      </thead>
      <tbody>
        <% @activity.parent_changes.each do |field, (old_value, new_value)| %>
          <tr>
            <td><code><%= field %></code></td>
            <td><%= format_audit_value(old_value) %></td>
            <td><%= format_audit_value(new_value) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="text-muted">No field-level changes recorded for this record.</p>
  <% end %>

  <% @activity.child_groups.each do |item_type, rows| %>
    <h3 class="section-header"><%= item_type.underscore.humanize.pluralize %></h3>
    <table class="table table-sm">
      <tbody>
        <% rows.each do |row| %>
          <tr>
            <td style="width: 8rem;"><%= audit_badge(row[:kind]) %></td>
            <td>
              <%= row[:label] %>
              <% if row[:kind] == :changed && row[:changes].any? %>
                <ul class="mb-0 small text-muted">
                  <% row[:changes].each do |field, (old_value, new_value)| %>
                    <li><code><%= field %></code>: <%= format_audit_value(old_value) %> → <%= format_audit_value(new_value) %></li>
                  <% end %>
                </ul>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>
</div>
